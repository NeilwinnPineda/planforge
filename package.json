{
  "name": "app-next",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:e2e": "playwright test",
    "test:e2e:parallel": "playwright test --workers=4",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:contracts": "node ../../tests/contracts/validate-construction-contract.mjs",
    "test:all": "npm run test && npm run test:contracts && npm run test:e2e",
    "debug:reporting-endpoint": "node scripts/reporting-endpoint-server.mjs",
    "debug:runtime-inspection": "node scripts/runtime-inspection.mjs",
    "export:live": "tsx scripts/export-live-contract.ts"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.22.4",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
