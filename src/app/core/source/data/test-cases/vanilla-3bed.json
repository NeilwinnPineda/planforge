  "intent": {
    "projectKind": "Detached single-storey residential house",
    "primaryGoal": "Baseline visual test. Produce stable, verified layouts with a standard family program on a comfortable suburban lot.",
    "narrative": "Three-bedroom family home on a 308 sqm suburban lot. Front setback 3m, side setbacks 1.5m, rear setback 2m. Room areas follow typical residential standards: living 22 sqm, master bed 18 sqm, secondary beds ~12 sqm each, kitchen and dining ~12 sqm each, garage 24 sqm. Total active program ~137 sqm against a 187 sqm buildable envelope — a comfortable 73% fit leaving room for hallways and fillers without pressure.",
    "priorities": [
      "Living and dining read as a connected public zone at the front.",
      "Master bedroom and ensuite are adjacent — private zone away from the street.",
      "Garage and foyer claim the street edge.",
      "Kitchen is adjacent to dining; laundry pairs with kitchen as a service cluster.",
      "Bedrooms 2 and 3 share the main bathroom."
    ],
    "downstreamTargets": [
      "buildable lot envelope",
      "room instance schedule",
      "adjacency matrix",
      "bubble simulation candidates",
      "orthogonal schematic layout",
      "future Revit room and wall creation"
    ]
  },
