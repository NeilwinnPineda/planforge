      "scope": "source.intent",
      "comment": "Treat this object as the project brief. The app should read design facts from here, while code only interprets and visualizes them."
    },
    {
      "scope": "lot.segments",
      "comment": "Segments are the survey boundary. Mark exactly one road/frontage segment with isRrow. The front edge is the street here."
    },
    {
      "scope": "rooms.catalog",
      "comment": "Catalog lists all available room types. Only rooms in settings.rooms.program are active for this run."
    },
    {
      "scope": "adjacency.exceptions",
      "comment": "Scores: 5=must-touch, 4=preferred, 3=neutral, 2=separation, 1=avoid. Pairs not listed use defaultScore (3)."
