  "intent": {
    "projectKind": "Lot-aware detached residential house layout",
    "primaryGoal": "Test feasibility on a narrow urban lot with a compact but complete residential program.",
    "narrative": "Narrow urban frontage with a compact residential brief that should still remain feasible. Lot is 10.5m × 22m. Buildable envelope after setbacks is roughly 7.3m × 16.5m = 120 sqm. Program totals about 100 sqm, leaving a slim margin for hallways and fillers. Expect some layout pressure on access and circulation.",
    "priorities": [
      "Garage and foyer must claim the narrow street frontage.",
      "Living and dining in a compact open-plan zone.",
      "Master suite at the rear away from the street noise.",
      "Kitchen adjacent to laundry as a service pair.",
      "Office tucked into a quiet secondary zone."
    ],
    "downstreamTargets": [
      "buildable lot envelope",
      "room instance schedule",
      "adjacency matrix",
      "bubble simulation candidates",
      "orthogonal schematic layout",
      "future Revit room and wall creation"
    ]
  },
