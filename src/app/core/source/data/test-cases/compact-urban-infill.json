    {
      "scope": "rules.special",
      "comment": "Special rules describe intent beyond the adjacency matrix. Behavior is enforced through scores and tags."
    },
    {
      "scope": "simulation.forces",
      "comment": "Force values tune search behavior only - not design intent."
    }
  ],
